// Finance GM Bot - Prisma Schema
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT_AGENT
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  LIFETIME
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum QRProvider {
  ABA
  ACLEDA
  WING
  KHQR
}

enum AnnouncementType {
  GLOBAL
  EXPIRATION_REMINDER
  MAINTENANCE
  PROMOTION
}

enum AnnouncementChannel {
  TELEGRAM
  IN_APP
  BOTH
}

// ─── User (existing + subscription fields) ──────────────────────────────────

model User {
  id           String   @id @default(cuid())
  telegramId   BigInt   @unique @map("telegram_id")
  firstName    String   @map("first_name")
  lastName     String?  @map("last_name")
  username     String?
  photoUrl     String?  @map("photo_url")
  languageCode String?  @map("language_code")
  currency     String   @default("USD")
  timezone     String   @default("UTC")
  isActive     Boolean  @default(true) @map("is_active")
  isBanned     Boolean  @default(false) @map("is_banned")
  isSuspended  Boolean  @default(false) @map("is_suspended")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Subscription
  plan              SubscriptionPlan   @default(FREE) @map("plan")
  subscriptionStatus SubscriptionStatus @default(TRIAL) @map("subscription_status")
  trialEndsAt       DateTime?          @map("trial_ends_at")
  premiumStartedAt  DateTime?          @map("premium_started_at")
  premiumExpiresAt  DateTime?          @map("premium_expires_at")

  transactions     Transaction[]
  budgets          Budget[]
  weeklyReports    WeeklyReport[]
  monthlyReports   MonthlyReport[]
  accounts         Account[]
  paymentRequests  PaymentRequest[]
  subscriptionLogs SubscriptionLog[]
  auditLogsTarget  AuditLog[]         @relation("AuditTargetUser")

  @@map("users")
}

// ─── Category ────────────────────────────────────────────────────────────────

model Category {
  id    String @id @default(cuid())
  name  String @unique
  label String
  icon  String
  color String
  type  String // 'income' | 'expense' | 'both'

  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

// ─── Transaction ─────────────────────────────────────────────────────────────

model Transaction {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  accountId  String?  @map("account_id")
  amount     Decimal  @db.Decimal(12, 2)
  type       String   // 'income' | 'expense'
  categoryId String   @map("category_id")
  note       String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account? @relation(fields: [accountId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@map("transactions")
}

// ─── Account ─────────────────────────────────────────────────────────────────

model Account {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  type         String   // 'cash' | 'bank' | 'card' | 'wallet' | 'savings' | 'investment'
  balance      Decimal  @default(0) @db.Decimal(12, 2)
  currency     String   @default("USD")
  color        String   @default("#6366f1")
  icon         String   @default("wallet")
  isDefault    Boolean  @default(false) @map("is_default")
  isFrozen     Boolean  @default(false) @map("is_frozen")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  transfersFrom AccountTransfer[] @relation("TransferFrom")
  transfersTo   AccountTransfer[] @relation("TransferTo")

  @@index([userId])
  @@map("accounts")
}

model AccountTransfer {
  id           String   @id @default(cuid())
  fromAccountId String  @map("from_account_id")
  toAccountId   String  @map("to_account_id")
  amount        Decimal @db.Decimal(12, 2)
  note          String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now()) @map("created_at")

  fromAccount Account @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   Account @relation("TransferTo", fields: [toAccountId], references: [id])

  @@map("account_transfers")
}

// ─── Budget ──────────────────────────────────────────────────────────────────

model Budget {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  amount     Decimal  @db.Decimal(12, 2)
  period     String   // 'weekly' | 'monthly'
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period, startDate])
  @@map("budgets")
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model WeeklyReport {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  weekStart        DateTime  @map("week_start")
  weekEnd          DateTime  @map("week_end")
  totalIncome      Decimal   @default(0) @map("total_income") @db.Decimal(12, 2)
  totalExpenses    Decimal   @default(0) @map("total_expenses") @db.Decimal(12, 2)
  netBalance       Decimal   @default(0) @map("net_balance") @db.Decimal(12, 2)
  savingsRate      Float     @default(0) @map("savings_rate")
  topCategory      String?   @map("top_category")
  transactionCount Int       @default(0) @map("transaction_count")
  reportData       Json?     @map("report_data")
  sentAt           DateTime? @map("sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("weekly_reports")
}

model MonthlyReport {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  month         Int
  year          Int
  totalIncome   Decimal   @default(0) @map("total_income") @db.Decimal(12, 2)
  totalExpenses Decimal   @default(0) @map("total_expenses") @db.Decimal(12, 2)
  netBalance    Decimal   @default(0) @map("net_balance") @db.Decimal(12, 2)
  savingsRate   Float     @default(0) @map("savings_rate")
  reportData    Json?     @map("report_data")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_reports")
}

// ─── Admin ───────────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String?   @map("last_name")
  role         AdminRole @default(SUPPORT_AGENT)
  permissions  String[]  @default([])
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdById  String?    @map("created_by_id")
  createdBy    AdminUser? @relation("AdminCreatedBy", fields: [createdById], references: [id])
  createdAdmins AdminUser[] @relation("AdminCreatedBy")

  auditLogs    AuditLog[]
  approvedPayments PaymentRequest[] @relation("ApprovedBy")
  announcements Announcement[]

  @@map("admin_users")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id           String    @id @default(cuid())
  adminId      String    @map("admin_id")
  action       String    // e.g. "user.suspend", "payment.approve", "balance.adjust"
  targetType   String    @map("target_type") // e.g. "user", "payment", "subscription"
  targetId     String?   @map("target_id")
  targetUserId String?   @map("target_user_id")
  oldValue     Json?     @map("old_value")
  newValue     Json?     @map("new_value")
  metadata     Json?
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  admin      AdminUser @relation(fields: [adminId], references: [id])
  targetUser User?     @relation("AuditTargetUser", fields: [targetUserId], references: [id])

  @@index([adminId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Payment Request ─────────────────────────────────────────────────────────

model PaymentRequest {
  id             String        @id @default(cuid())
  userId         String        @map("user_id")
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("USD")
  plan           SubscriptionPlan @map("plan")
  durationDays   Int           @map("duration_days")
  qrProvider     QRProvider?   @map("qr_provider")
  screenshotUrl  String?       @map("screenshot_url")
  note           String?
  status         PaymentStatus @default(PENDING)
  reviewedById   String?       @map("reviewed_by_id")
  reviewedAt     DateTime?     @map("reviewed_at")
  rejectReason   String?       @map("reject_reason")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy AdminUser? @relation("ApprovedBy", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_requests")
}

// ─── Subscription Log ────────────────────────────────────────────────────────

model SubscriptionLog {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  action     String           // "trial_start" | "premium_activate" | "premium_expire" | "suspend" | "cancel" | "extend"
  plan       SubscriptionPlan
  startDate  DateTime?        @map("start_date")
  endDate    DateTime?        @map("end_date")
  note       String?
  createdAt  DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscription_logs")
}

// ─── QR Code ─────────────────────────────────────────────────────────────────

model QRCode {
  id          String     @id @default(cuid())
  provider    QRProvider @unique
  imageUrl    String     @map("image_url")
  accountName String?    @map("account_name")
  accountNumber String?  @map("account_number")
  instructions String?
  isActive    Boolean    @default(true) @map("is_active")
  uploadedById String?   @map("uploaded_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("qr_codes")
}

// ─── Announcement ────────────────────────────────────────────────────────────

model Announcement {
  id          String              @id @default(cuid())
  title       String
  message     String
  type        AnnouncementType    @default(GLOBAL)
  channel     AnnouncementChannel @default(BOTH)
  targetUserIds String[]          @default([]) @map("target_user_ids")
  sentAt      DateTime?           @map("sent_at")
  scheduledAt DateTime?           @map("scheduled_at")
  createdById String              @map("created_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")

  createdBy AdminUser @relation(fields: [createdById], references: [id])

  @@map("announcements")
}

// ─── System Settings ─────────────────────────────────────────────────────────

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
