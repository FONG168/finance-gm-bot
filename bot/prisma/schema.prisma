// Finance GM Bot - Prisma Schema
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  telegramId   BigInt   @unique @map("telegram_id")
  firstName    String   @map("first_name")
  lastName     String?  @map("last_name")
  username     String?
  photoUrl     String?  @map("photo_url")
  languageCode String?  @map("language_code")
  currency     String   @default("USD")
  timezone     String   @default("UTC")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions   Transaction[]
  accounts       Account[]
  budgets        Budget[]
  weeklyReports  WeeklyReport[]
  monthlyReports MonthlyReport[]

  @@map("users")
}

model Account {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  type        String   // 'cash' | 'bank' | 'ewallet' | 'savings' | 'credit'
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  currency    String   @default("USD")
  color       String   @default("#7c3aed")
  icon        String   @default("💵")
  isArchived  Boolean  @default(false) @map("is_archived")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  label String
  icon  String
  color String
  type  String // 'income' | 'expense' | 'both'

  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  accountId  String?  @map("account_id")
  amount     Decimal  @db.Decimal(12, 2)
  type       String   // 'income' | 'expense' | 'transfer'
  categoryId String   @map("category_id")
  note       String?
  transferId String?  @map("transfer_id")
  date       DateTime @default(now())
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category Category  @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@index([userId, accountId])
  @@map("transactions")
}

model Budget {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  amount     Decimal  @db.Decimal(12, 2)
  period     String   // 'weekly' | 'monthly'
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period, startDate])
  @@map("budgets")
}

model WeeklyReport {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  weekStart        DateTime @map("week_start")
  weekEnd          DateTime @map("week_end")
  totalIncome      Decimal  @default(0) @map("total_income") @db.Decimal(12, 2)
  totalExpenses    Decimal  @default(0) @map("total_expenses") @db.Decimal(12, 2)
  netBalance       Decimal  @default(0) @map("net_balance") @db.Decimal(12, 2)
  savingsRate      Float    @default(0) @map("savings_rate")
  topCategory      String?  @map("top_category")
  transactionCount Int      @default(0) @map("transaction_count")
  reportData       Json?    @map("report_data") // CategoryBreakdown[] stored as JSON
  sentAt           DateTime? @map("sent_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("weekly_reports")
}

model MonthlyReport {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  month         Int
  year          Int
  totalIncome   Decimal  @default(0) @map("total_income") @db.Decimal(12, 2)
  totalExpenses Decimal  @default(0) @map("total_expenses") @db.Decimal(12, 2)
  netBalance    Decimal  @default(0) @map("net_balance") @db.Decimal(12, 2)
  savingsRate   Float    @default(0) @map("savings_rate")
  reportData    Json?    @map("report_data") // Full report data as JSON
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_reports")
}
