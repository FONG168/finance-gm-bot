# ============================================================
# Finance GM Bot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (Supabase PostgreSQL) ──────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/finance_gm?schema=public&sslmode=require"

# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN="your_bot_token_here"

# ── Frontend (Next.js) ───────────────────────────────────────
# The URL where your Next.js app is deployed (Vercel URL)
FRONTEND_URL="https://your-app.vercel.app"

# Public env vars (exposed to browser)
NEXT_PUBLIC_API_URL="https://your-backend.railway.app/api"
NEXT_PUBLIC_BOT_USERNAME="YourBotUsername"

# ── Backend (Express) ─────────────────────────────────────────
PORT=3001
NODE_ENV="production"

# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET="your_super_secret_jwt_key_here_min_32_chars"
JWT_EXPIRES_IN="7d"

# CORS — set to your frontend URL
CORS_ORIGIN="https://your-app.vercel.app"

# ── AI Features (future) ──────────────────────────────────────
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
